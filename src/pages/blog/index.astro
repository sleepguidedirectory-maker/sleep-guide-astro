<script>
  // Accordion
  document.querySelectorAll('.acc-trigger').forEach(function(trigger) {
    trigger.addEventListener('click', function() {
      var item = this.closest('.acc-item');
      var isOpen = item.classList.contains('open');
      // Close all
      document.querySelectorAll('.acc-item.open').forEach(function(el) {
        el.classList.remove('open');
        el.querySelector('.acc-trigger').setAttribute('aria-expanded', 'false');
      });
      // Open clicked if it was closed
      if (!isOpen) {
        item.classList.add('open');
        this.setAttribute('aria-expanded', 'true');
        // Smooth scroll into view on mobile
        if (window.innerWidth < 640) {
          setTimeout(function() {
            item.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          }, 100);
        }
      }
    });
  });

  // Search
  var searchInput = document.getElementById('search-input');
  var noResults = document.getElementById('no-results');

  searchInput.addEventListener('input', function() {
    var q = this.value.toLowerCase().trim();
    var visibleCount = 0;

    document.querySelectorAll('.acc-item').forEach(function(item) {
      var title = (item.dataset.title || '').toLowerCase();
      var desc = (item.querySelector('.acc-desc') ? item.querySelector('.acc-desc').textContent : '').toLowerCase();
      var tag = (item.querySelector('.acc-tag') ? item.querySelector('.acc-tag').textContent : '').toLowerCase();
      var match = !q || title.includes(q) || desc.includes(q) || tag.includes(q);
      item.style.display = match ? '' : 'none';
      if (match) visibleCount++;
    });

    // Hide empty category groups
    document.querySelectorAll('.category-group').forEach(function(group) {
      var visible = group.querySelectorAll('.acc-item:not([style*="display: none"])').length;
      group.style.display = visible > 0 ? '' : 'none';
    });

    noResults.style.display = visibleCount === 0 ? 'block' : 'none';
  });
</script>

