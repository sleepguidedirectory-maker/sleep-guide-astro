<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SleepGuide.com.au — Australia's Trusted Sleep Resource</title>
  <meta name="description" content="Expert mattress and pillow reviews, honest comparisons and trusted sleep guides for Australians. Find your perfect night's sleep in 2026." />
  <link rel="canonical" href="https://www.sleepguide.com.au/" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="SleepGuide.com.au — Australia's Trusted Sleep Resource" />
  <meta property="og:description" content="Expert mattress and pillow reviews, honest comparisons and trusted sleep guides for Australians. Find your perfect night's sleep in 2026." />
  <meta property="og:url" content="https://www.sleepguide.com.au/" />
  <meta property="og:site_name" content="SleepGuide.com.au" />
  <meta property="og:locale" content="en_AU" />
  <meta property="og:image" content="https://images.unsplash.com/photo-1631157769375-6df2ced3e0d9?w=1200&q=80" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="SleepGuide.com.au — Australia's Trusted Sleep Resource" />
  <meta name="twitter:description" content="Expert mattress and pillow reviews, honest comparisons and trusted sleep guides for Australians." />
  <meta name="twitter:image" content="https://images.unsplash.com/photo-1631157769375-6df2ced3e0d9?w=1200&q=80" />
  <meta name="robots" content="index, follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy: #1B2B4B;
      --gold: #C49A45;
      --cream: #FAF8F3;
      --warm-bg: #F2EDE3;
      --muted: #6B7B8A;
      --text: #1B2B4B;
      --white: #ffffff;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--cream);
      color: var(--text);
      line-height: 1.6;
    }

    a { text-decoration: none; color: inherit; }

    /* NAV */
    nav {
      background: var(--navy);
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      color: var(--cream);
      font-weight: 600;
    }
    .nav-logo span { color: var(--gold); }
    .nav-links {
      display: flex;
      gap: 1.8rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.85rem;
      color: rgba(250,248,243,0.75);
      font-weight: 400;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--gold); }

    /* HERO */
    .hero {
      background: var(--navy);
      padding: 5rem 2rem 4rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -80px; left: -80px;
      width: 300px; height: 300px;
      border-radius: 50%;
      background: rgba(196,154,69,0.07);
    }
    .hero::after {
      content: '';
      position: absolute;
      bottom: -60px; right: -60px;
      width: 250px; height: 250px;
      border-radius: 50%;
      background: rgba(196,154,69,0.05);
    }
    .hero-tag {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid rgba(196,154,69,0.4);
      padding: 6px 16px;
      border-radius: 20px;
      margin-bottom: 1.5rem;
    }
    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.2rem, 5vw, 3.4rem);
      font-weight: 600;
      color: var(--cream);
      line-height: 1.2;
      max-width: 620px;
      margin: 0 auto 1.2rem;
    }
    .hero h1 em {
      color: var(--gold);
      font-style: italic;
    }
    .hero-sub {
      font-size: 1rem;
      color: rgba(250,248,243,0.65);
      font-weight: 300;
      max-width: 460px;
      margin: 0 auto 2rem;
      line-height: 1.75;
    }
    .hero-btns {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn-gold {
      background: var(--gold);
      color: var(--navy);
      padding: 13px 28px;
      border-radius: 6px;
      font-size: 0.9rem;
      font-weight: 500;
      transition: opacity 0.2s;
    }
    .btn-gold:hover { opacity: 0.88; }
    .btn-outline {
      background: transparent;
      color: var(--cream);
      padding: 13px 28px;
      border-radius: 6px;
      font-size: 0.9rem;
      font-weight: 400;
      border: 1px solid rgba(250,248,243,0.3);
      transition: border-color 0.2s;
    }
    .btn-outline:hover { border-color: rgba(250,248,243,0.6); }

    /* TRUST BAR */
    .trust-bar {
      background: var(--warm-bg);
      padding: 0.9rem 2rem;
      display: flex;
      justify-content: center;
      gap: 2.5rem;
      flex-wrap: wrap;
      border-bottom: 1px solid rgba(27,43,75,0.08);
    }
    .trust-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.78rem;
      color: var(--muted);
      font-weight: 500;
    }
    .trust-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--gold);
      flex-shrink: 0;
    }

    /* SECTIONS */
    .section {
      padding: 3.5rem 2rem;
      max-width: 1100px;
      margin: 0 auto;
    }
    .section-label {
      font-size: 0.7rem;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--gold);
      font-weight: 500;
      margin-bottom: 0.4rem;
    }
    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.6rem, 3vw, 2rem);
      font-weight: 600;
      color: var(--navy);
      margin-bottom: 0.5rem;
    }
    .section-sub {
      font-size: 0.9rem;
      color: var(--muted);
      font-weight: 300;
      margin-bottom: 2rem;
      max-width: 480px;
      line-height: 1.7;
    }

    /* CATEGORIES */
    .cat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
    }
    .cat-card {
      border-radius: 12px;
      padding: 2rem 1.5rem;
      transition: transform 0.25s, box-shadow 0.25s;
      cursor: pointer;
    }
    .cat-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(27,43,75,0.15);
    }
    .cat-mattress { background: var(--navy); }
    .cat-pillow { background: #2D4A3E; }
    .cat-back { background: #3D2B1F; }
    .cat-science { background: #3A2A45; }
    .cat-icon {
      font-size: 1.8rem;
      margin-bottom: 1rem;
      display: block;
    }
    .cat-card h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--cream);
      margin-bottom: 0.4rem;
    }
    .cat-card p {
      font-size: 0.8rem;
      color: rgba(250,248,243,0.55);
      font-weight: 300;
      line-height: 1.6;
      margin-bottom: 0.8rem;
    }
    .cat-badge {
      display: inline-block;
      font-size: 0.65rem;
      background: rgba(196,154,69,0.2);
      color: var(--gold);
      padding: 3px 10px;
      border-radius: 12px;
      font-weight: 500;
      letter-spacing: 0.5px;
    }

    /* FEATURED ARTICLE */
    .featured-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    @media (max-width: 640px) {
      .featured-grid { grid-template-columns: 1fr; }
      .nav-links { display: none; }
      .cat-grid { grid-template-columns: 1fr 1fr; }
    }
    .article-card {
      background: var(--white);
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid rgba(27,43,75,0.08);
      transition: box-shadow 0.25s, transform 0.25s;
    }
    .article-card:hover {
      box-shadow: 0 8px 28px rgba(27,43,75,0.1);
      transform: translateY(-2px);
    }
    .article-card.featured {
      grid-column: span 2;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    @media (max-width: 640px) {
      .article-card.featured {
        grid-column: span 1;
        grid-template-columns: 1fr;
      }
    }
    .article-img {
      height: 160px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.5rem;
    }
    .article-card.featured .article-img { height: 100%; min-height: 200px; }
    .img-mattress { background: linear-gradient(135deg, #E8EAF2, #C8CEDF); }
    .img-pillow { background: linear-gradient(135deg, #E8F0E8, #C8DFC8); }
    .img-koala { background: linear-gradient(135deg, #EDE8F0, #D5C8DF); }
    .img-pregnancy { background: linear-gradient(135deg, #F0EBE8, #DFD0C8); }
    .img-back { background: linear-gradient(135deg, #EAF0E8, #D0E0CC); }
    .img-latex { background: linear-gradient(135deg, #F0EDE8, #E0D5C0); }
    .img-snore { background: linear-gradient(135deg, #E8ECF0, #C8D2E0); }
    .img-contour { background: linear-gradient(135deg, #E8F0EC, #C8DFD4); }
    .img-weighted { background: linear-gradient(135deg, #EDE8F0, #D4C8DF); }
    .article-body { padding: 1.2rem 1.3rem; }
    .article-tag {
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.4rem;
    }
    .article-card h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-weight: 600;
      color: var(--navy);
      line-height: 1.4;
      margin-bottom: 0.5rem;
    }
    .article-card.featured h3 { font-size: 1.3rem; }
    .article-desc {
      font-size: 0.82rem;
      color: var(--muted);
      font-weight: 300;
      line-height: 1.65;
      margin-bottom: 0.8rem;
    }
    .article-meta {
      font-size: 0.72rem;
      color: #9BA8B4;
      font-weight: 300;
    }
    .read-more {
      display: inline-block;
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--gold);
      margin-top: 0.8rem;
    }
    .read-more::after { content: ' →'; }

    /* SLEEP SCORE SECTION */
    .score-section {
      background: var(--navy);
      padding: 4rem 2rem;
      text-align: center;
    }
    .score-section .section-label { color: var(--gold); }
    .score-section .section-title { color: var(--cream); margin: 0 auto 0.5rem; }
    .score-section .section-sub {
      color: rgba(250,248,243,0.6);
      max-width: 420px;
      margin: 0 auto 1.5rem;
    }
    .score-steps {
      display: flex;
      justify-content: center;
      gap: 2rem;
      flex-wrap: wrap;
      margin-bottom: 2rem;
    }
    .score-step {
      text-align: center;
      max-width: 130px;
    }
    .step-num {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: rgba(196,154,69,0.2);
      border: 1px solid rgba(196,154,69,0.4);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--gold);
      margin: 0 auto 0.6rem;
    }
    .score-step p {
      font-size: 0.78rem;
      color: rgba(250,248,243,0.55);
      font-weight: 300;
      line-height: 1.5;
    }

    /* FOOTER */
    footer {
      background: #111E33;
      padding: 2.5rem 2rem 1.5rem;
    }
    .footer-inner {
      max-width: 1100px;
      margin: 0 auto;
    }
    .footer-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      color: var(--cream);
      margin-bottom: 0.4rem;
    }
    .footer-logo span { color: var(--gold); }
    .footer-tagline {
      font-size: 0.8rem;
      color: rgba(250,248,243,0.4);
      font-weight: 300;
      margin-bottom: 1.5rem;
    }
    .footer-links {
      display: flex;
      gap: 1.8rem;
      flex-wrap: wrap;
      margin-bottom: 1.5rem;
    }
    .footer-links a {
      font-size: 0.8rem;
      color: rgba(250,248,243,0.5);
      transition: color 0.2s;
    }
    .footer-links a:hover { color: var(--gold); }
    .footer-copy {
      font-size: 0.72rem;
      color: rgba(250,248,243,0.25);
      border-top: 1px solid rgba(250,248,243,0.08);
      padding-top: 1rem;
    }
  </style>
</head>
