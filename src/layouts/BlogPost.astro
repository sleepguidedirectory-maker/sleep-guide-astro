---
interface Props {
  title: string;
  pubDate: string;
  description: string;
  categories?: string[];
  heroImage?: string;
}
const { title, pubDate, description, categories, heroImage } = Astro.props;

const formattedDate = new Date(pubDate).toLocaleDateString('en-AU', {
  year: 'numeric', month: 'long', day: 'numeric'
});
const category = categories?.[0] || 'Sleep Guide';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{title} | SleepGuide.com.au</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={`https://www.sleepguide.com.au${Astro.url.pathname}`} />

  <meta property="og:type" content="article" />
  <meta property="og:title" content={`${title} | SleepGuide.com.au`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={`https://www.sleepguide.com.au${Astro.url.pathname}`} />
  <meta property="og:site_name" content="SleepGuide.com.au" />
  <meta property="og:locale" content="en_AU" />
  {heroImage && <meta property="og:image" content={heroImage} />}
  {!heroImage && <meta property="og:image" content="https://images.pexels.com/photos/6585598/pexels-photo-6585598.jpeg?w=1200" />}
  <meta property="article:published_time" content={pubDate} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | SleepGuide.com.au`} />
  <meta name="twitter:description" content={description} />
  {heroImage && <meta name="twitter:image" content={heroImage} />}
  <meta name="robots" content="index, follow" />
  <meta name="author" content="SleepGuide.com.au" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy: #1B2B4B; --gold: #C49A45; --cream: #FAF8F3;
      --warm: #F2EDE3; --muted: #6B7B8A; --white: #ffffff;
      --border: rgba(27,43,75,0.09); --text: #2C3E55;
    }
    body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); line-height: 1.7; }
    a { text-decoration: none; color: inherit; }

    /* NAV */
    nav.site-nav { background: var(--navy); padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 100; }
    .nav-logo { font-family: 'Playfair Display', serif; font-size: 1.2rem; color: var(--cream); font-weight: 600; }
    .nav-logo span { color: var(--gold); }
    .nav-links { display: flex; gap: 1.8rem; list-style: none; }
    .nav-links a { font-size: 0.85rem; color: rgba(250,248,243,0.7); transition: color 0.2s; }
    .nav-links a:hover { color: var(--gold); }
    @media (max-width: 640px) { .nav-links { display: none; } }

    /* HERO */
    .article-hero { background: var(--navy); padding: 3rem 2rem 3.5rem; position: relative; overflow: hidden; }
    .article-hero::before { content: ''; position: absolute; top: -60px; right: -60px; width: 250px; height: 250px; border-radius: 50%; background: rgba(196,154,69,0.07); pointer-events: none; }
    .hero-inner { max-width: 820px; margin: 0 auto; position: relative; z-index: 1; }
    .article-breadcrumb { display: flex; align-items: center; gap: 8px; margin-bottom: 1.2rem; flex-wrap: wrap; }
    .article-breadcrumb a { font-size: 0.75rem; color: rgba(250,248,243,0.45); transition: color 0.2s; }
    .article-breadcrumb a:hover { color: var(--gold); }
    .breadcrumb-sep { font-size: 0.75rem; color: rgba(250,248,243,0.2); }
    .article-category { display: inline-block; font-size: 0.65rem; font-weight: 500; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); border: 1px solid rgba(196,154,69,0.35); padding: 4px 12px; border-radius: 20px; margin-bottom: 1rem; }
    .article-hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(1.7rem, 4vw, 2.6rem); font-weight: 700; color: var(--cream); line-height: 1.2; margin-bottom: 1rem; }
    .article-description { font-size: 1rem; color: rgba(250,248,243,0.62); font-weight: 300; line-height: 1.75; margin-bottom: 1.5rem; max-width: 640px; }
    .article-meta { display: flex; align-items: center; gap: 1.2rem; flex-wrap: wrap; }
    .meta-item { display: flex; align-items: center; gap: 6px; font-size: 0.78rem; color: rgba(250,248,243,0.45); }
    .meta-divider { width: 1px; height: 12px; background: rgba(250,248,243,0.15); }

    /* HERO IMAGE */
    .article-hero-img-wrap { max-height: 420px; overflow: hidden; }
    .article-hero-img { width: 100%; max-height: 420px; object-fit: cover; display: block; }

    /* LAYOUT WRAPPER */
    .article-outer { max-width: 1100px; margin: 0 auto; padding: 3rem 1.5rem 4rem; display: grid; grid-template-columns: 1fr 280px; gap: 3rem; align-items: start; }
    @media (max-width: 900px) { .article-outer { grid-template-columns: 1fr; } }

    /* TABLE OF CONTENTS */
    .toc-sidebar { position: sticky; top: 80px; }
    @media (max-width: 900px) { .toc-sidebar { position: static; order: -1; } }
    .toc-box { background: var(--white); border: 1px solid var(--border); border-radius: 12px; padding: 1.4rem; }
    .toc-title { font-size: 0.7rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; display: flex; align-items: center; gap: 8px; }
    .toc-title::before { content: ''; display: block; width: 16px; height: 2px; background: var(--gold); border-radius: 2px; }
    #toc-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 2px; }
    #toc-list li a { font-size: 0.82rem; color: var(--muted); line-height: 1.5; display: block; padding: 5px 8px; border-radius: 6px; transition: all 0.2s; border-left: 2px solid transparent; }
    #toc-list li a:hover { color: var(--navy); background: var(--warm); border-left-color: var(--gold); }
    #toc-list li a.toc-active { color: var(--navy); font-weight: 500; background: rgba(196,154,69,0.08); border-left-color: var(--gold); }
    #toc-list li.toc-h3 a { padding-left: 1.2rem; font-size: 0.78rem; }
    .toc-empty { font-size: 0.82rem; color: var(--muted); font-style: italic; }

    /* ARTICLE CONTENT */
    .article-content { min-width: 0; }

    /* TYPOGRAPHY */
    .prose { font-size: 1.02rem; line-height: 1.88; color: var(--text); }
    .prose > * + * { margin-top: 1.4rem; }

    .prose h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.3rem, 2.5vw, 1.65rem);
      font-weight: 700;
      color: var(--navy);
      line-height: 1.3;
      margin-top: 3rem;
      margin-bottom: 1rem;
      padding-bottom: 0.7rem;
      border-bottom: 2px solid var(--warm);
      scroll-margin-top: 90px;
    }
    .prose h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--navy);
      margin-top: 2.2rem;
      margin-bottom: 0.6rem;
      scroll-margin-top: 90px;
    }
    .prose h4 {
      font-size: 0.98rem;
      font-weight: 600;
      color: var(--navy);
      margin-top: 1.6rem;
      margin-bottom: 0.4rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .prose p { margin-bottom: 1.3rem; }
    .prose p:last-child { margin-bottom: 0; }
    .prose strong { font-weight: 600; color: var(--navy); }
    .prose em { font-style: italic; color: inherit; }
    .prose a { color: var(--gold); text-decoration: underline; text-decoration-color: rgba(196,154,69,0.35); text-underline-offset: 3px; transition: text-decoration-color 0.2s; }
    .prose a:hover { text-decoration-color: var(--gold); }

    /* LISTS */
    .prose ul { list-style: none; padding: 0; margin: 0.5rem 0 1.4rem; display: flex; flex-direction: column; gap: 0.5rem; }
    .prose ul li { display: flex; align-items: flex-start; gap: 10px; padding: 0.4rem 0; line-height: 1.65; }
    .prose ul li::before { content: ''; width: 8px; height: 8px; border-radius: 50%; background: var(--gold); flex-shrink: 0; margin-top: 0.45rem; opacity: 0.8; }
    .prose ol { list-style: none; padding: 0; margin: 0.5rem 0 1.4rem; counter-reset: ol-c; display: flex; flex-direction: column; gap: 0.5rem; }
    .prose ol li { display: flex; align-items: flex-start; gap: 12px; counter-increment: ol-c; padding: 0.4rem 0; line-height: 1.65; }
    .prose ol li::before { content: counter(ol-c); min-width: 24px; height: 24px; background: var(--navy); color: var(--gold); border-radius: 50%; font-size: 0.68rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 0.2rem; }

    /* NESTED LISTS */
    .prose li ul, .prose li ol { margin: 0.4rem 0 0 1rem; }
    .prose li ul li::before { width: 5px; height: 5px; opacity: 0.5; }

    /* BLOCKQUOTE */
    .prose blockquote { border-left: 3px solid var(--gold); background: rgba(196,154,69,0.05); padding: 1.2rem 1.5rem; margin: 2rem 0; border-radius: 0 10px 10px 0; }
    .prose blockquote p { font-family: 'Playfair Display', serif; font-style: italic; font-size: 1.05rem; color: var(--navy); margin: 0; line-height: 1.65; }

    /* TABLES */
    .prose table { width: 100%; border-collapse: collapse; margin: 2rem 0; font-size: 0.88rem; border-radius: 10px; overflow: hidden; border: 1px solid var(--border); display: block; overflow-x: auto; }
    .prose th { background: var(--navy); color: var(--cream); padding: 0.8rem 1rem; text-align: left; font-weight: 500; font-size: 0.8rem; letter-spacing: 0.3px; white-space: nowrap; }
    .prose td { padding: 0.75rem 1rem; border-bottom: 1px solid var(--border); vertical-align: top; }
    .prose tr:last-child td { border-bottom: none; }
    .prose tr:nth-child(even) td { background: rgba(242,237,227,0.45); }

    /* IMAGES */
    .prose img { max-width: 100%; height: auto; border-radius: 10px; margin: 1.8rem 0; display: block; border: 1px solid var(--border); }
    .prose figure { margin: 2rem 0; }
    .prose figcaption { font-size: 0.78rem; color: var(--muted); text-align: center; margin-top: 0.6rem; font-style: italic; line-height: 1.5; }

    /* HORIZONTAL RULE */
    .prose hr { border: none; border-top: 2px solid var(--warm); margin: 2.5rem 0; }

    /* ARTICLE FOOTER */
    .article-footer-bar { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem 3rem; }
    .article-footer-inner { border-top: 1px solid var(--border); padding-top: 1.8rem; display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem; }
    .footer-back a { display: inline-flex; align-items: center; gap: 7px; font-size: 0.85rem; color: var(--muted); transition: color 0.2s; }
    .footer-back a:hover { color: var(--gold); }
    .footer-disclaimer { font-size: 0.75rem; color: var(--muted); max-width: 500px; line-height: 1.65; font-weight: 300; }

    /* NEWSLETTER */
    .newsletter-section { background: var(--navy); padding: 3.5rem 2rem; position: relative; overflow: hidden; }
    .newsletter-section::before { content: ''; position: absolute; top: -80px; right: -80px; width: 300px; height: 300px; border-radius: 50%; background: rgba(196,154,69,0.06); pointer-events: none; }
    .newsletter-inner { max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 3.5rem; align-items: center; }
    @media (max-width: 680px) { .newsletter-inner { grid-template-columns: 1fr; gap: 2rem; } }
    .nl-tag { display: inline-block; font-size: 0.65rem; font-weight: 500; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); border: 1px solid rgba(196,154,69,0.3); padding: 4px 12px; border-radius: 20px; margin-bottom: 1rem; }
    .newsletter-left h2 { font-family: 'Playfair Display', serif; font-size: clamp(1.4rem, 3vw, 1.9rem); font-weight: 600; color: var(--cream); line-height: 1.25; margin-bottom: 0.8rem; }
    .newsletter-left h2 em { color: var(--gold); font-style: italic; }
    .newsletter-left p { font-size: 0.88rem; color: rgba(250,248,243,0.6); font-weight: 300; line-height: 1.75; margin-bottom: 1.2rem; }
    .nl-perks { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
    .nl-perks li { display: flex; align-items: center; gap: 9px; font-size: 0.82rem; color: rgba(250,248,243,0.65); }
    .perk-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--gold); flex-shrink: 0; }
    .newsletter-right { background: rgba(255,255,255,0.04); border: 1px solid rgba(250,248,243,0.1); border-radius: 14px; padding: 1.8rem; }
    .nl-form { display: flex; flex-direction: column; gap: 0.9rem; }
    .nl-field { display: flex; flex-direction: column; gap: 5px; }
    .nl-field label { font-size: 0.75rem; font-weight: 500; color: rgba(250,248,243,0.55); }
    .nl-field input { background: rgba(255,255,255,0.07); border: 1px solid rgba(250,248,243,0.15); border-radius: 7px; padding: 10px 13px; font-size: 0.88rem; color: var(--cream); outline: none; font-family: inherit; transition: border-color 0.2s; }
    .nl-field input::placeholder { color: rgba(250,248,243,0.28); }
    .nl-field input:focus { border-color: rgba(196,154,69,0.5); }
    .nl-submit { background: var(--gold); color: var(--navy); border: none; border-radius: 7px; padding: 12px; font-size: 0.88rem; font-weight: 600; cursor: pointer; font-family: inherit; transition: opacity 0.2s; margin-top: 0.2rem; }
    .nl-submit:hover { opacity: 0.88; }
    .nl-fine { font-size: 0.7rem; color: rgba(250,248,243,0.3); text-align: center; margin: 0; }

    /* SITE FOOTER */
    footer { background: #111E33; padding: 2rem; text-align: center; }
    .footer-links { display: flex; justify-content: center; gap: 1.8rem; flex-wrap: wrap; margin-bottom: 0.7rem; }
    .footer-links a { font-size: 0.78rem; color: rgba(250,248,243,0.4); transition: color 0.2s; }
    .footer-links a:hover { color: var(--gold); }
    .footer-copy { font-size: 0.72rem; color: rgba(250,248,243,0.18); }
  </style>
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-CN2MKZB7F7"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag("js", new Date());
    gtag("config", "G-CN2MKZB7F7");
  </script>
</head>
<body>

  <nav class="site-nav">
    <a href="/" class="nav-logo">Sleep<span>Guide</span><span style="color:rgba(250,248,243,0.28);font-size:0.62rem;font-family:'DM Sans',sans-serif;font-weight:300;margin-left:3px">.com.au</span></a>
    <ul class="nav-links">
      <li><a href="/best-mattress-in-australia-2026/">Mattresses</a></li>
      <li><a href="/blog/best-anti-snore-pillow-australia/">Pillows</a></li>
      <li><a href="/sleep-score-optimizer/">Sleep Quiz</a></li>
      <li><a href="/about-us/">About</a></li>
      <li><a href="/contact/">Contact</a></li>
    </ul>
  </nav>

  <header class="article-hero">
    <div class="hero-inner">
      <nav class="article-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb-sep">›</span>
        <a href="/">Guides</a>
        <span class="breadcrumb-sep">›</span>
        <span style="color:rgba(250,248,243,0.35);font-size:0.75rem">{title}</span>
      </nav>
      <div class="article-category">{category}</div>
      <h1>{title}</h1>
      {description && <p class="article-description">{description}</p>}
      <div class="article-meta">
        <div class="meta-item">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          {formattedDate}
        </div>
        <div class="meta-divider"></div>
        <div class="meta-item">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span id="read-time">8 min read</span>
        </div>
        <div class="meta-divider"></div>
        <div class="meta-item">🇦🇺 Australian guide</div>
      </div>
    </div>
  </header>

  {heroImage && (
    <div class="article-hero-img-wrap">
      <img src={heroImage} alt={title} class="article-hero-img" loading="eager" />
    </div>
  )}

  <div class="article-outer">
    <main class="article-content">
      <div class="prose" id="article-prose">
        <slot />
      </div>
    </main>

    <aside class="toc-sidebar">
      <div class="toc-box">
        <div class="toc-title">In this guide</div>
        <ul id="toc-list"><li><span class="toc-empty">Loading...</span></li></ul>
      </div>
    </aside>
  </div>

  <div class="article-footer-bar">
    <div class="article-footer-inner">
      <div class="footer-back">
        <a href="/">← Back to all guides</a>
      </div>
      <p class="footer-disclaimer">Content on SleepGuide.com.au is for informational purposes only and does not constitute medical advice. Always consult a health professional for sleep-related concerns.</p>
    </div>
  </div>

  <!-- NEWSLETTER -->
  <section class="newsletter-section">
    <div class="newsletter-inner">
      <div class="newsletter-left">
        <div class="nl-tag">Free sleep tips</div>
        <h2>Sleep better, starting <em>tonight</em></h2>
        <p>Join Australians getting our weekly sleep tips, mattress deals and expert guides — straight to your inbox.</p>
        <ul class="nl-perks">
          <li><span class="perk-dot"></span>Weekly sleep science digest</li>
          <li><span class="perk-dot"></span>Exclusive AU mattress deals</li>
          <li><span class="perk-dot"></span>New guide alerts</li>
        </ul>
      </div>
      <div class="newsletter-right">
        <div class="ml-embedded" data-form="h1sjom"></div>
      </div>
    </div>
  </section>
  <script>
    (function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[])
    .push(arguments);},l=d.createElement(e),l.async=1,l.src=u,
    n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})
    (window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
    ml('account', '2307218');
  </script>

  <footer>
    <div class="footer-links">
      <a href="/about-us/">About</a>
      <a href="/contact/">Contact</a>
      <a href="/privacy-policy/">Privacy Policy</a>
      <a href="/terms-of-service/">Terms</a>
    </div>
    <p class="footer-copy">© 2026 SleepGuide.com.au · Australia's trusted sleep resource</p>
  </footer>

  <script>
    // Auto-generate Table of Contents from headings
    (function() {
      var prose = document.getElementById('article-prose');
      var tocList = document.getElementById('toc-list');
      if (!prose || !tocList) return;

      var headings = prose.querySelectorAll('h2, h3');
      if (headings.length === 0) {
        tocList.innerHTML = '<li><span class="toc-empty">No sections found</span></li>';
        return;
      }

      // Add IDs to headings and build TOC
      var items = [];
      headings.forEach(function(h, i) {
        var slug = h.textContent.toLowerCase()
          .replace(/[^a-z0-9\s-]/g, '')
          .replace(/\s+/g, '-')
          .replace(/-+/g, '-')
          .trim();
        slug = slug || ('section-' + i);
        h.id = slug;

        var li = document.createElement('li');
        li.className = h.tagName === 'H3' ? 'toc-h3' : '';
        var a = document.createElement('a');
        a.href = '#' + slug;
        a.textContent = h.textContent;
        li.appendChild(a);
        tocList.appendChild(li);
        items.push({ el: h, link: a });
      });

      tocList.innerHTML = '';
      items.forEach(function(item) {
        var li = document.createElement('li');
        li.className = item.el.tagName === 'H3' ? 'toc-h3' : '';
        li.appendChild(item.link);
        tocList.appendChild(li);
      });

      // Smooth scroll
      tocList.querySelectorAll('a').forEach(function(a) {
        a.addEventListener('click', function(e) {
          e.preventDefault();
          var target = document.getElementById(this.getAttribute('href').slice(1));
          if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });

      // Active state on scroll
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          var id = entry.target.id;
          var link = tocList.querySelector('a[href="#' + id + '"]');
          if (link) {
            if (entry.isIntersecting) {
              tocList.querySelectorAll('a').forEach(function(a) { a.classList.remove('toc-active'); });
              link.classList.add('toc-active');
            }
          }
        });
      }, { rootMargin: '-80px 0px -60% 0px' });

      items.forEach(function(item) { observer.observe(item.el); });

      // Estimate read time
      var words = prose.textContent.split(/\s+/).length;
      var mins = Math.max(1, Math.round(words / 220));
      var rt = document.getElementById('read-time');
      if (rt) rt.textContent = mins + ' min read';
    })();
  </script>

</body>
</html>
